{
  "manifest_version": 2,
  "name": "GifCopyPaster",
  "version": "2.0.0",
  "description": "Right-click any GIF or MP4 on the web to copy it to your clipboard.",

  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },

  "permissions": [
    "contextMenus",
    "nativeMessaging",
    "activeTab",
    "notifications"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "gifcopypaster@local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
